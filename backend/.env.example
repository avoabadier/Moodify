SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
OPENWEATHER_API_KEY=

# Market Spotify Search results are scoped to. Mood queries are currently
# OPM-anchored (see backend/config/moodMap.js), so this defaults to PH.
SPOTIFY_MARKET=PH

# Fallback location used when the browser denies/lacks geolocation.
# Defaults to Manila, Philippines.
DEFAULT_CITY_LAT=14.5995
DEFAULT_CITY_LON=120.9842
DEFAULT_CITY_NAME=Manila

PORT=3001
